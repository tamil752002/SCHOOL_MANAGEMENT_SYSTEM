{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "db:push": "node database/push-schema.js",
    "build:server": "tsc",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "server": "cross-env CLUSTER_MODE=false tsx server.ts",
    "start:prod": "cross-env NODE_ENV=production node dist/server.js",
    "start:cluster": "cross-env NODE_ENV=production CLUSTER_MODE=true node dist/server.js",
    "start": "node dist/server.js",
    "load-test:health": "k6 run load-tests/health-check.js",
    "load-test:data": "k6 run load-tests/data-endpoint.js",
    "load-test:developer": "k6 run load-tests/developer-data.js",
    "load-test:auth": "k6 run load-tests/auth-load.js",
    "load-test:mixed": "k6 run load-tests/mixed-workload.js",
    "load-test:stress": "k6 run load-tests/stress-test.js",
    "load-test:cache": "k6 run load-tests/cache-test.js",
    "load-test:all": "npm run load-test:health && npm run load-test:data && npm run load-test:mixed",
    "deploy": "./deploy.sh"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "firebase": "^12.7.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^3.0.4",
    "lucide-react": "^0.344.0",
    "morgan": "^1.10.1",
    "pg": "^8.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.11.0",
    "recharts": "^3.7.0",
    "redis": "^5.10.0",
    "terser": "^5.44.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.2.0",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.21",
    "vitest": "^3.2.4"
  }
}